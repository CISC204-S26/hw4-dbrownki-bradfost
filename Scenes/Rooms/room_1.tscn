[node name="SignInteractable3" parent="." unique_id=1837391755 instance=ExtResource("4_476il")]
position = Vector2(144, 312)
text = ["Myah", "If it isn't Mr. Ghost still looking for his very much dead body", "That dead body that is NOT at the locked room at the end of the hallway", "And that locked room that you definitely dont need to collect 10 orbs to open", "And looking through the tombs using E will definitely not help in that hunt", "And there is definitely not orbs in the two side rooms..."]

[node name="FinalDoor" parent="." unique_id=389972689 instance=ExtResource("11_vwayj")]
