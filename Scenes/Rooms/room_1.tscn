text = ["Ah! You found my hiding spot!", "Well... technically the only spot I've ever been.", "Since I can't really move...", "Being a dead body and all... y'know?", "...", "Uhh... wait, I don't recognize you.", "You must be new here.", "Glad you could join the party!", "Well, not much of a party, actually.", "It's more like some games we all try to play, like hide and seek.", "Though, as you could probably tell, some of these games are kind of hard to play.", "But, they help pass the time until we slowly rot away into nothing.", "Like the book club some of my buddies put together!", "Although we don't actually have any books...", "And now that I mention it, I haven't seen them around lately.", "...eh... they probably moved on.", "But you could be one of my new buddies!", "In fact, you'll fit right in with all the rest of us!", "There's plenty of vacant tombs around here.", "So pop a squat and get comfy!"]

[node name="HiddenSideTombInteractable5" parent="." unique_id=1294680167 node_paths=PackedStringArray("hiddenElement") instance=ExtResource("10_7rrix")]
