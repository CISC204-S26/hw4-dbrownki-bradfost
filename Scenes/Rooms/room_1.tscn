[node name="SignInteractable3" parent="HiddenSideTombInteractable5" unique_id=2086660060 instance=ExtResource("4_476il")]
scale = Vector2(-1, 1)
text = ["*It seems that this pile of bones has lost its voice*", "*Many others likely shared a similar fate*", "*Lets hope it doesn't happen to you*"]

