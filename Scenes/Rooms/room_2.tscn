[node name="Daw-Soul" parent="." unique_id=622266382 instance=ExtResource("6_n7ha0")]
position = Vector2(48, 128)
rotation = 3.1415927
scale = Vector2(1, -1)
text = ["HELLO THERE!!!!!", "You found us, the greatest things to ever find!", "What are we, you might be asking???", "Well, I'm so glad you definitely asked!", "We are the Bony Bros.!", "I'm Daw-Soul.", "And the guy to my right is Boo-Rad.", "Super cool guy. Definitely recommend talking to him.", "He's actually the one that started that whole thing you might've seen with the other guys.", "Y'know, the \"Myah?\"", "All him, broski.", "He's got like a whole fan club in here.", "And me? I just chill; hang with my bro.", "Oh, and by the way.", "He's got a pretty impressive BONE collection.", "He'll tell you all about it if you ask him.", "But uhh... that's about all I have to share.", "Thanks for visiting, broski!"]

[node name="Boo-Rad" parent="." unique_id=921978400 instance=ExtResource("6_n7ha0")]
position = Vector2(48, 160)
rotation = 3.1415927
scale = Vector2(1, -1)
text = ["I'm Boo-Rad.", "Pretty sure you've met my bro over there, Daw-Soul.", "What a guy.", "I heard he was trying to make some game with like 23 other guys in here.", "Pretty wild stuff.", "Hey you should come to his playtest.", "I tried asking as many people as I could for the last one he did.", "Tried to spread the word, you know.", "And we got a good amount of people to show up.", "Except for one, you know.", "He kind of flaked last minute.", "But its alright; we got the feedback.", "But, whatever you do...", "Don't ask Daw-Soul about mirrors.", "He doesn't know how to use them.", "He might say he does, but he doesn't know.", "So don't ask."]

